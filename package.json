{
  "name": "chiller-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Web view of a G&D glycol chiller (Carel c.pCO) over Modbus TCP + HTTP — read-only except an opt-in automatic setpoint boost",
  "main": "chiller_dashboard.js",
  "scripts": {
    "start": "node chiller_dashboard.js",
    "dev": "DEV=1 node --watch-path=chiller_dashboard.js --watch-path=dashboard.html --watch-path=lib --watch-path=public chiller_dashboard.js",
    "test": "node test.js",
    "typecheck": "tsc -p jsconfig.json"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3",
    "modbus-serial": "^8.0.17",
    "three": "^0.185.1",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
